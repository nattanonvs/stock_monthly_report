<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_stock_fifo_asof_wizard_form" model="ir.ui.view">
    <field name="name">stock.fifo.asof.wizard.form</field>
    <field name="model">stock.fifo.asof.wizard</field>
    <field name="arch" type="xml">
      <form string="FIFO Valuation (As-of Date)">
        <group>
          <field name="asof_datetime"/>
          <field name="location_ids" widget="many2many_tags"/>
          <field name="include_sub_locations"/>
        </group>

        <group string="Filters">
          <field name="categ_ids" widget="many2many_tags"/>
          <field name="product_ids" widget="many2many_tags" domain="[]"/>
          <field name="summary_only"/>
        </group>

        <group string="Output">
          <field name="include_excel"/>
        </group>

        <footer>
          <button name="action_generate_asof_xlsx" type="object" string="Generate XLSX" class="btn-primary"/>
          <button string="Cancel" special="cancel" class="btn-secondary"/>
        </footer>
      </form>
    </field>
  </record>

  <record id="action_stock_fifo_asof_wizard" model="ir.actions.act_window">
    <field name="name">FIFO Valuation (As-of Date)</field>
    <field name="res_model">stock.fifo.asof.wizard</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
  </record>
</odoo>
