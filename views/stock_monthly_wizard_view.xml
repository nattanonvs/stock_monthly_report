<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_stock_monthly_wizard_form" model="ir.ui.view">
        <field name="name">stock.monthly.wizard.form</field>
        <field name="model">stock.monthly.wizard</field>
        <field name="arch" type="xml">
            <form string="Monthly Stock Report">
                <group>
                    <group>
                        <field name="year" options="{'grouping': False}"/>
                        <field name="month_start"/>
                        <field name="month_end"/>
                    </group>
                    <group>
                        <field name="include_pdf"/>
                        <field name="include_excel"/>
                        <field name="summary_only"/>
                        <field name="show_movements" attrs="{'invisible':[('summary_only','=',True)]}"/>
                    </group>
                </group>

                <separator string="Filters"/>

                <group>
                    <group>
                        <field name="location_id"/>
                        <field name="include_sub_locations"/>
                        <field name="include_zero_qty"/>
                    </group>

                    <group>
                        <field name="categ_id"/>
                        <field name="product_ids" widget="many2many_tags"
                               domain="[('categ_id','child_of',categ_id)]"
                               attrs="{'readonly':[('categ_id','!=',False)]}"/>
                        <div class="o_form_label">Tip: เลือก Products จะ override Category (ถ้าเลือก Products แล้วจะไม่ใช้ Category)</div>
                    </group>
                </group>

                <separator string="Email (Optional)"/>

                <group>
                    <field name="send_email"/>
                    <group attrs="{'invisible':[('send_email','=',False)]}">
                        <field name="email_to"/>
                        <field name="email_cc"/>
                        <field name="email_bcc"/>
                    </group>
                </group>

                <group attrs="{'invisible':[('send_email','=',False)]}">
                    <field name="email_body" nolabel="1"/>
                </group>

<footer>
    <button
        name="action_open_stock_quantity_history"
        type="object"
        string="Open Inventory at Date"
        class="btn-secondary"
    />
    <button
        name="action_generate_reports"
        type="object"
        string="Generate Report"
        class="btn-primary"
    />
    <button string="Cancel" class="btn-secondary" special="cancel"/>
</footer>
            </form>
        </field>
    </record>

</odoo>
